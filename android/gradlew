#!/bin/bash
##############################################################################
## Gradle start up script for UN*X
##############################################################################

# Attempt to set APP_HOME

# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while [ -h "$app_path" ]; do
    ls=$(ls -ld "$app_path")
    link=${ls#*' -> '}
    case $link in
        /*)   app_path=$link ;;  # absolute
        *)    app_path="$(dirname "$app_path")/$link" ;;  # relative
    esac
done

APP_HOME=$( cd "$(dirname "$app_path")" && pwd ) || exit

APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}

DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Use the maximum available, set MAX_FD to -1
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo "$*"
    exit 1
} >&2

# OS specific support
native_path() { echo "$1"; }
case "$(uname)" in
    CYGWIN* | MINGW* | MSYS* )
        native_path() { cygpath --path --windows "$1"; }
        ;;
esac

# Collect all arguments for the java command
set -- \
    "-Dorg.gradle.appname=$APP_BASE_NAME" \
    -classpath "$(native_path "$APP_HOME/gradle/wrapper/gradle-wrapper.jar")" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"

# Determine the Java command
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "JAVA_HOME is set to an invalid directory: $JAVA_HOME"
    fi
else
    JAVACMD=java
    which java >/dev/null 2>&1 || die "JAVA_HOME is not set and no 'java' command found"
fi

exec "$JAVACMD" "$@"
